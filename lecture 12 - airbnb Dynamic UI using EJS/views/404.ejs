<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <link rel="stylesheet" href="/output.css" />
  <!-- Import Outfit or Inter font for premium aesthetics -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300..800;1,300..800&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
    }
    h1, .font-serif {
      font-family: 'Playfair Display', serif;
    }
  </style>
</head>

<body class="bg-gray-50/50 min-h-screen">
  <!-- Airbnb Header -->
  <header class="bg-[#FF5A5F] py-4 px-6 shadow-md flex items-center justify-between sticky top-0 z-50">
    <div class="flex gap-3">
      <a href="/" class="px-4 py-2 rounded-lg font-bold text-sm flex items-center gap-1.5 transition duration-200 <%= (typeof currentPage !== 'undefined' && currentPage === 'home') ? 'bg-white text-[#FF5A5F] shadow-sm' : 'text-white hover:bg-white/10' %>">
        <span>🏠</span> Go to Home
      </a>
      <a href="/host/add-home" class="px-4 py-2 rounded-lg font-bold text-sm flex items-center gap-1.5 transition duration-200 <%= (typeof currentPage !== 'undefined' && currentPage === 'add-home') ? 'bg-white text-[#FF5A5F] shadow-sm' : 'text-white hover:bg-white/10' %>">
        <span>➕</span> Add Home
      </a>
    </div>
    <div class="text-white font-extrabold text-2xl tracking-tight select-none flex items-center gap-1.5">
      <span class="text-3xl">🏡</span> <span class="hidden sm:inline font-serif font-bold">airbnb</span>
    </div>
  </header>

  <!-- Content -->
  <main class="max-w-md mx-auto p-6 mt-16">
    <div class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden p-8 text-center">
      <h1 class="text-9xl font-black text-rose-500 tracking-tighter mb-4 select-none drop-shadow-sm animate-pulse">404</h1>
      <h2 class="text-2xl font-bold text-gray-800 mb-3 font-serif">Oops! Page Not Found</h2>
      <p class="text-gray-500 mb-8">We can't find the page you are looking for. Let's get you back on track!</p>
      <a href="/" 
         class="inline-block bg-[#FF5A5F] text-white font-extrabold py-3.5 px-8 rounded-xl hover:bg-red-600 hover:scale-105 active:scale-95 shadow-md shadow-red-200 transition duration-200">
        Go Back Home
      </a>
    </div>
  </main>
</body>

</html>
