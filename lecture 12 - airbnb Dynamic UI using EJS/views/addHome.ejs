<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <link rel="stylesheet" href="/output.css" />
  <!-- Import Outfit or Inter font for premium aesthetics -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300..800;1,300..800&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
    }
    h1, .font-serif {
      font-family: 'Playfair Display', serif;
    }
  </style>
</head>

<body class="bg-gray-50/50 min-h-screen">
  <!-- Airbnb Header -->
  <header class="bg-[#FF5A5F] py-4 px-6 shadow-md flex items-center justify-between sticky top-0 z-50">
    <div class="flex gap-3">
      <a href="/" class="px-4 py-2 rounded-lg font-bold text-sm flex items-center gap-1.5 transition duration-200 <%= currentPage === 'home' ? 'bg-white text-[#FF5A5F] shadow-sm' : 'text-white hover:bg-white/10' %>">
        <span>🏠</span> Go to Home
      </a>
      <a href="/host/add-home" class="px-4 py-2 rounded-lg font-bold text-sm flex items-center gap-1.5 transition duration-200 <%= currentPage === 'add-home' ? 'bg-white text-[#FF5A5F] shadow-sm' : 'text-white hover:bg-white/10' %>">
        <span>➕</span> Add Home
      </a>
    </div>
    <div class="text-white font-extrabold text-2xl tracking-tight select-none flex items-center gap-1.5">
      <span class="text-3xl">🏡</span> <span class="hidden sm:inline font-serif font-bold">airbnb</span>
    </div>
  </header>

  <!-- Content -->
  <main class="max-w-2xl mx-auto p-6 my-10">
    <div class="bg-white rounded-3xl shadow-2xl border border-gray-100 overflow-hidden">
      <!-- Header banner -->
      <div class="bg-gradient-to-r from-red-500 to-[#FF5A5F] p-8 text-center text-white relative">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,rgba(255,255,255,0.1),transparent)] pointer-events-none"></div>
        <span class="text-6xl block mb-3 drop-shadow">🏡</span>
        <h1 class="text-3xl font-extrabold font-serif tracking-tight">Register Your Home on Airbnb</h1>
        <p class="text-white/85 text-sm mt-2 max-w-md mx-auto">Fill in the details below to publish your beautiful listing for travelers worldwide.</p>
      </div>

      <form action="/host/add-home" method="post" id="addHomeForm" class="p-8 space-y-6">
        <!-- Grid for general details -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- House Name -->
          <div class="md:col-span-2">
            <label for="houseName" class="block text-gray-700 font-extrabold text-sm mb-2 flex items-center gap-1.5">
              <span>🏷️</span> House Name
            </label>
            <input type="text" id="houseName" name="houseName" placeholder="e.g. Luxury Beachside Villa" 
                   class="border border-gray-200 px-4 py-3.5 rounded-2xl w-full focus:outline-none focus:ring-2 focus:ring-[#FF5A5F]/50 focus:border-[#FF5A5F] text-gray-800 transition duration-200 shadow-sm" 
                   required>
          </div>

          <!-- Price Per Night in Rupees -->
          <div>
            <label for="price" class="block text-gray-700 font-extrabold text-sm mb-2 flex items-center gap-1.5">
              <span>💰</span> Price per night
            </label>
            <div class="relative rounded-2xl shadow-sm">
              <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                <span class="text-gray-500 font-bold text-base">₹</span>
              </div>
              <input type="number" id="price" name="price" min="1" placeholder="999" 
                     class="border border-gray-200 pl-8 pr-4 py-3.5 rounded-2xl w-full focus:outline-none focus:ring-2 focus:ring-[#FF5A5F]/50 focus:border-[#FF5A5F] text-gray-800 transition duration-200" 
                     required>
              <div class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none">
                <span class="text-xs text-gray-400 font-bold">INR / night</span>
              </div>
            </div>
          </div>

          <!-- Location -->
          <div>
            <label for="location" class="block text-gray-700 font-extrabold text-sm mb-2 flex items-center gap-1.5">
              <span>📍</span> Location / City
            </label>
            <input type="text" id="location" name="location" placeholder="e.g. Goa, India" 
                   class="border border-gray-200 px-4 py-3.5 rounded-2xl w-full focus:outline-none focus:ring-2 focus:ring-[#FF5A5F]/50 focus:border-[#FF5A5F] text-gray-800 transition duration-200 shadow-sm" 
                   required>
          </div>
        </div>

        <!-- Rating Interactive Stars Selector -->
        <div>
          <label class="block text-gray-700 font-extrabold text-sm mb-2 flex items-center gap-1.5">
            <span>⭐</span> Rating
          </label>
          <div class="flex items-center gap-2 bg-gray-50 p-3.5 rounded-2xl border border-gray-100">
            <input type="hidden" name="rating" id="ratingInput" value="5">
            <div class="flex gap-1.5" id="starContainer">
              <% for (let i = 1; i <= 5; i++) { %>
                <button type="button" data-value="<%= i %>" class="star-btn text-3xl text-amber-400 hover:scale-125 transition duration-150 focus:outline-none">★</button>
              <% } %>
            </div>
            <span class="ml-3 text-sm font-extrabold text-gray-500" id="ratingText">5.0 / 5.0 (Excellent)</span>
          </div>
        </div>

        <!-- Photo Section -->
        <div>
          <label class="block text-gray-700 font-extrabold text-sm mb-2 flex items-center gap-1.5">
            <span>📸</span> Original Picture of House
          </label>
          <input type="hidden" name="photoUrl" id="photoUrl" required>

          <!-- Tab Bar -->
          <div class="flex border-b border-gray-200 mb-4 bg-gray-50/50 p-1 rounded-xl">
            <button type="button" id="tab-url-btn" onclick="selectTab('url')" 
                    class="flex-1 py-2 px-3 text-xs font-bold rounded-lg transition duration-200 text-center bg-white text-gray-800 shadow-sm border border-gray-100">
              🔗 Image URL
            </button>
            <button type="button" id="tab-upload-btn" onclick="selectTab('upload')" 
                    class="flex-1 py-2 px-3 text-xs font-bold rounded-lg transition duration-200 text-center text-gray-500 hover:text-gray-800">
              📁 Upload File
            </button>
            <button type="button" id="tab-camera-btn" onclick="selectTab('camera')" 
                    class="flex-1 py-2 px-3 text-xs font-bold rounded-lg transition duration-200 text-center text-gray-500 hover:text-gray-800 flex items-center justify-center gap-1">
              📷 Click Picture
            </button>
          </div>

          <!-- Tab Content 1: URL -->
          <div id="tab-content-url" class="space-y-3">
            <input type="url" id="photoUrlField" placeholder="https://images.unsplash.com/... or paste link" 
                   class="border border-gray-200 px-4 py-3.5 rounded-2xl w-full focus:outline-none focus:ring-2 focus:ring-[#FF5A5F]/50 focus:border-[#FF5A5F] text-gray-800 transition duration-200"
                   oninput="handleUrlInput(this.value)">
            <p class="text-xs text-gray-400">Enter a public image URL from Unsplash, Pexels, etc.</p>
          </div>

          <!-- Tab Content 2: Upload File -->
          <div id="tab-content-upload" class="hidden">
            <div id="dropzone" 
                 class="border-2 border-dashed border-gray-200 hover:border-[#FF5A5F] rounded-2xl p-6 text-center cursor-pointer transition duration-200 bg-gray-50/30 flex flex-col items-center justify-center min-h-[160px]"
                 onclick="document.getElementById('fileInput').click()">
              <span class="text-4xl mb-2">📤</span>
              <p class="text-sm font-bold text-gray-600">Drag & Drop house picture here</p>
              <p class="text-xs text-gray-400 mt-1">or click to browse from device</p>
              <input type="file" id="fileInput" accept="image/*" class="hidden" onchange="handleFileUpload(event)">
            </div>
          </div>

          <!-- Tab Content 3: Camera Capture -->
          <div id="tab-content-camera" class="hidden space-y-4">
            <div class="relative rounded-2xl overflow-hidden bg-gray-950 flex flex-col items-center justify-center min-h-[220px] shadow-inner">
              <video id="webcam" class="w-full max-h-[260px] object-cover hidden" autoplay playsinline></video>
              <div id="cameraPlaceholder" class="text-center p-6 flex flex-col items-center">
                <span class="text-5xl mb-3 animate-pulse">📷</span>
                <p class="text-sm font-bold text-gray-400 mb-4">Device Camera Interface</p>
                <button type="button" onclick="startCamera()" 
                        class="bg-[#FF5A5F] text-white px-5 py-2.5 rounded-xl font-bold text-xs shadow-md hover:bg-red-600 active:scale-95 transition duration-150">
                  Enable Camera Stream
                </button>
              </div>
              <!-- Snap / Switch Action controls inside camera box -->
              <div id="cameraControls" class="absolute bottom-3 left-1/2 -translate-x-1/2 hidden flex items-center gap-3 bg-black/60 backdrop-blur px-4 py-2 rounded-2xl">
                <button type="button" onclick="capturePhoto()" 
                        class="bg-white hover:bg-gray-100 text-gray-900 w-12 h-12 rounded-full flex items-center justify-center shadow-lg active:scale-90 transition font-bold border border-white">
                  📸
                </button>
                <button type="button" onclick="stopCamera()" class="text-white hover:text-red-400 text-xs px-2 font-semibold">
                  Cancel
                </button>
              </div>
            </div>
            <p class="text-xs text-gray-400 text-center">Give camera permission when prompted to click original picture of the house.</p>
          </div>

          <!-- Dynamic Live Thumbnail Preview Container -->
          <div id="previewContainer" class="mt-4 p-4 bg-gray-50 rounded-2xl border border-gray-100 hidden flex items-center gap-4 relative overflow-hidden group">
            <div class="w-20 h-20 rounded-xl overflow-hidden shadow-md border border-white flex-shrink-0">
              <img id="imagePreview" src="" class="w-full h-full object-cover" alt="Home preview">
            </div>
            <div class="flex-grow">
              <h4 class="text-xs font-extrabold text-gray-700">Image Loaded Successfully</h4>
              <p class="text-[10px] text-gray-400 mt-0.5 truncate" id="previewFileName">Custom Image File / Source</p>
              <span class="inline-flex items-center gap-1 text-[10px] text-emerald-600 font-extrabold bg-emerald-50 px-2 py-0.5 rounded-full mt-1.5">
                <span>✓</span> Ready to Submit
              </span>
            </div>
            <button type="button" onclick="clearPreview()" 
                    class="absolute top-2 right-2 bg-white text-gray-400 border border-gray-200 hover:border-red-200 hover:text-red-500 w-6 h-6 rounded-full flex items-center justify-center text-xs shadow-sm hover:scale-105 active:scale-95 transition">
              ✕
            </button>
          </div>
        </div>

        <button type="submit" 
                class="bg-[#FF5A5F] text-white font-extrabold py-4 px-6 rounded-2xl w-full hover:bg-red-600 hover:scale-[1.01] shadow-xl shadow-red-200 active:scale-[0.99] transition duration-200 text-base">
          Publish Listing
        </button>
      </form>
    </div>
  </main>

  <!-- Interactive form scripts -->
  <script>
    // Tab Controller
    let currentTab = 'url';
    let localStream = null;

    function selectTab(tab) {
      if (currentTab === 'camera' && tab !== 'camera') {
        stopCamera();
      }

      currentTab = tab;
      
      // Update UI buttons
      const tabs = ['url', 'upload', 'camera'];
      tabs.forEach(t => {
        const btn = document.getElementById(`tab-${t}-btn`);
        const content = document.getElementById(`tab-content-${t}`);
        
        if (t === tab) {
          btn.className = "flex-1 py-2 px-3 text-xs font-bold rounded-lg transition duration-200 text-center bg-white text-gray-800 shadow-sm border border-gray-100";
          content.classList.remove('hidden');
        } else {
          btn.className = "flex-1 py-2 px-3 text-xs font-bold rounded-lg transition duration-200 text-center text-gray-500 hover:text-gray-800";
          content.classList.add('hidden');
        }
      });

      // Clear main photo input on tab switch to avoid mismatched values
      clearPreview();
    }

    // Star rating hover and click mechanics
    const starContainer = document.getElementById('starContainer');
    const ratingInput = document.getElementById('ratingInput');
    const ratingText = document.getElementById('ratingText');
    const stars = starContainer.querySelectorAll('.star-btn');
    const ratingDescriptions = {
      1: "1.0 / 5.0 (Poor)",
      2: "2.0 / 5.0 (Fair)",
      3: "3.0 / 5.0 (Good)",
      4: "4.0 / 5.0 (Very Good)",
      5: "5.0 / 5.0 (Excellent)"
    };

    stars.forEach(star => {
      star.addEventListener('click', () => {
        const val = parseInt(star.getAttribute('data-value'));
        ratingInput.value = val;
        ratingText.textContent = ratingDescriptions[val];
        updateStarColors(val);
      });
    });

    function updateStarColors(val) {
      stars.forEach(s => {
        const sVal = parseInt(s.getAttribute('data-value'));
        if (sVal <= val) {
          s.classList.remove('text-gray-300');
          s.classList.add('text-amber-400');
        } else {
          s.classList.remove('text-amber-400');
          s.classList.add('text-gray-300');
        }
      });
    }

    // Input handlers
    function setPhotoUrl(val, fileName = "Custom Source") {
      document.getElementById('photoUrl').value = val;
      document.getElementById('imagePreview').src = val;
      document.getElementById('previewFileName').textContent = fileName;
      document.getElementById('previewContainer').classList.remove('hidden');
    }

    function handleUrlInput(val) {
      if (val.trim()) {
        setPhotoUrl(val.trim(), "Remote Web URL");
      } else {
        clearPreview();
      }
    }

    function handleFileUpload(event) {
      const file = event.target.files[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = function(e) {
          setPhotoUrl(e.target.result, file.name);
        };
        reader.readAsDataURL(file);
      }
    }

    // Camera capture module
    async function startCamera() {
      const video = document.getElementById('webcam');
      const placeholder = document.getElementById('cameraPlaceholder');
      const controls = document.getElementById('cameraControls');

      try {
        localStream = await navigator.mediaDevices.getUserMedia({
          video: { facingMode: 'environment' }, // captures back camera on mobile or front webcam on pc
          audio: false
        });
        
        video.srcObject = localStream;
        video.classList.remove('hidden');
        placeholder.classList.add('hidden');
        controls.classList.remove('hidden');
      } catch (err) {
        console.error("Camera access failed", err);
        alert("Unable to open device camera. Please check camera permissions or upload an image file instead.");
      }
    }

    function stopCamera() {
      const video = document.getElementById('webcam');
      const placeholder = document.getElementById('cameraPlaceholder');
      const controls = document.getElementById('cameraControls');

      if (localStream) {
        localStream.getTracks().forEach(track => track.stop());
        localStream = null;
      }
      
      video.classList.add('hidden');
      placeholder.classList.remove('hidden');
      controls.classList.add('hidden');
      video.srcObject = null;
    }

    function capturePhoto() {
      const video = document.getElementById('webcam');
      if (!localStream) return;

      const canvas = document.createElement('canvas');
      canvas.width = video.videoWidth || 640;
      canvas.height = video.videoHeight || 480;
      
      const ctx = canvas.getContext('2d');
      ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
      
      const dataUrl = canvas.toDataURL('image/jpeg', 0.85);
      setPhotoUrl(dataUrl, `captured_house_photo_${Date.now()}.jpg`);
      stopCamera();
    }

    function clearPreview() {
      document.getElementById('photoUrl').value = '';
      document.getElementById('imagePreview').src = '';
      document.getElementById('previewFileName').textContent = '';
      document.getElementById('previewContainer').classList.add('hidden');
      
      // reset specific fields
      document.getElementById('photoUrlField').value = '';
      document.getElementById('fileInput').value = '';
    }

    // Drag and Drop File Upload listener
    const dropzone = document.getElementById('dropzone');
    if (dropzone) {
      ['dragenter', 'dragover'].forEach(eventName => {
        dropzone.addEventListener(eventName, (e) => {
          e.preventDefault();
          dropzone.classList.add('border-[#FF5A5F]', 'bg-red-50/10');
        }, false);
      });

      ['dragleave', 'drop'].forEach(eventName => {
        dropzone.addEventListener(eventName, (e) => {
          e.preventDefault();
          dropzone.classList.remove('border-[#FF5A5F]', 'bg-red-50/10');
        }, false);
      });

      dropzone.addEventListener('drop', (e) => {
        const dt = e.dataTransfer;
        const files = dt.files;
        if (files.length) {
          const file = files[0];
          const reader = new FileReader();
          reader.onload = function(evt) {
            setPhotoUrl(evt.target.result, file.name);
          };
          reader.readAsDataURL(file);
        }
      }, false);
    }
  </script>
</body>

</html>
