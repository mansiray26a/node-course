<%- include('../partials/head') %>
<%- include('../partials/nav') %>

  <!-- Content -->
  <main class="max-w-6xl mx-auto p-6 md:p-8">
    <h1 class="text-center text-4xl md:text-5xl font-extrabold text-gray-800 mt-8 mb-12 font-serif tracking-tight">Browse All Homes</h1>

    <% if (homes.length === 0) { %>
      <div class="text-center py-16 bg-white rounded-3xl shadow-xl border border-gray-100 max-w-xl mx-auto px-6">
        <span class="text-7xl block mb-6 animate-bounce">🏡</span>
        <h2 class="text-2xl font-bold text-gray-700 mb-3">No Homes Available</h2>
        <p class="text-gray-500 mb-8 max-w-md mx-auto">There are no homes listed yet. Be the first host!</p>
        <a href="/host/add-home" class="inline-block bg-[#FF5A5F] text-white px-8 py-3.5 rounded-xl font-bold text-lg hover:bg-red-600 hover:scale-105 shadow-md shadow-red-200 transition duration-300">
          Register Your Home
        </a>
      </div>
    <% } else { %>
      <!-- Results Count -->
      <p class="text-gray-500 text-sm font-bold mb-6"><%= homes.length %> home<%= homes.length > 1 ? 's' : '' %> available</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
        <% homes.forEach(home => { %>
          <div class="bg-white rounded-3xl overflow-hidden shadow-lg border border-gray-100 hover:shadow-2xl transition duration-300 transform hover:-translate-y-1.5 flex flex-col">
            <!-- Image with Link -->
            <a href="/homes/<%= home.id %>" class="h-52 overflow-hidden relative group select-none block">
              <img src="<%= home.photoUrl %>" alt="<%= home.name %>"
                   class="w-full h-full object-cover group-hover:scale-105 transition duration-500">
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent pointer-events-none"></div>
              <!-- Rating Badge -->
              <span class="absolute top-4 right-4 bg-white/95 backdrop-blur-sm text-xs font-black text-rose-500 px-3 py-1 rounded-full shadow-sm flex items-center gap-1">
                <span>★</span> <%= parseFloat(home.rating).toFixed(1) %>
              </span>

              <!-- Favourite indicator -->
              <% if (favouriteIds.includes(home.id)) { %>
                <span class="absolute top-4 left-4 text-2xl drop-shadow-lg">❤️</span>
              <% } %>
            </a>

            <div class="p-6 flex-grow flex flex-col justify-between">
              <div>
                <a href="/homes/<%= home.id %>" class="hover:text-[#FF5A5F] transition">
                  <h3 class="text-xl font-extrabold text-gray-800 tracking-tight leading-tight mb-2"><%= home.name %></h3>
                </a>
                <p class="text-gray-500 text-sm flex items-center gap-1.5 mb-4">
                  <span class="text-base">📍</span> <%= home.location %>
                </p>
              </div>
              <div class="pt-4 border-t border-gray-100 mt-auto">
                <div class="flex items-center justify-between mb-3">
                  <span class="text-xl font-black text-[#FF5A5F]">₹<%= parseInt(home.price).toLocaleString('en-IN') %><span class="text-xs font-bold text-gray-400"> / night</span></span>
                  <span class="text-[10px] bg-emerald-50 text-emerald-600 font-extrabold px-3 py-1 rounded-full tracking-wider uppercase">Available</span>
                </div>
                <!-- Action Buttons -->
                <div class="flex gap-2">
                  <a href="/homes/<%= home.id %>" class="flex-1 text-center bg-[#FF5A5F] text-white text-xs font-bold py-2.5 rounded-xl hover:bg-red-600 transition">
                    View Details
                  </a>
                  <% if (favouriteIds.includes(home.id)) { %>
                    <form action="/favourites/remove" method="POST" class="flex-shrink-0">
                      <input type="hidden" name="homeId" value="<%= home.id %>">
                      <input type="hidden" name="redirectTo" value="/homes">
                      <button type="submit" class="bg-rose-100 text-rose-500 text-xs font-bold py-2.5 px-3 rounded-xl hover:bg-rose-200 transition" title="Remove from Wishlist">
                        ❤️
                      </button>
                    </form>
                  <% } else { %>
                    <form action="/favourites" method="POST" class="flex-shrink-0">
                      <input type="hidden" name="homeId" value="<%= home.id %>">
                      <button type="submit" class="bg-gray-100 text-gray-400 text-xs font-bold py-2.5 px-3 rounded-xl hover:bg-rose-50 hover:text-rose-400 transition" title="Add to Wishlist">
                        🤍
                      </button>
                    </form>
                  <% } %>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </main>

</body>
</html>
