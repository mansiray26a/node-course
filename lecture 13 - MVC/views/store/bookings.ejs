<%- include('../partials/head') %>
<%- include('../partials/nav') %>

  <!-- Content -->
  <main class="max-w-5xl mx-auto p-6 md:p-8">
    <h1 class="text-center text-4xl md:text-5xl font-extrabold text-gray-800 mt-8 mb-4 font-serif tracking-tight">My Bookings</h1>
    <p class="text-center text-gray-500 mb-12">Manage your upcoming and past reservations</p>

    <% if (bookings.length === 0) { %>
      <div class="text-center py-16 bg-white rounded-3xl shadow-xl border border-gray-100 max-w-xl mx-auto px-6">
        <span class="text-7xl block mb-6">📅</span>
        <h2 class="text-2xl font-bold text-gray-700 mb-3">No Bookings Yet</h2>
        <p class="text-gray-500 mb-8 max-w-md mx-auto">You haven't made any bookings yet. Browse homes and book your dream stay!</p>
        <a href="/homes" class="inline-block bg-[#FF5A5F] text-white px-8 py-3.5 rounded-xl font-bold text-lg hover:bg-red-600 hover:scale-105 shadow-md shadow-red-200 transition duration-300">
          Browse Homes
        </a>
      </div>
    <% } else { %>
      <div class="space-y-6">
        <% bookings.forEach(booking => { %>
          <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden flex flex-col md:flex-row hover:shadow-xl transition duration-300">
            <!-- Image -->
            <div class="md:w-64 h-48 md:h-auto overflow-hidden flex-shrink-0">
              <img src="<%= booking.homePhoto %>" alt="<%= booking.homeName %>"
                   class="w-full h-full object-cover">
            </div>

            <!-- Info -->
            <div class="flex-grow p-6 flex flex-col justify-between">
              <div>
                <div class="flex items-start justify-between">
                  <div>
                    <h3 class="text-xl font-extrabold text-gray-800 mb-1"><%= booking.homeName %></h3>
                    <p class="text-gray-500 text-sm flex items-center gap-1.5 mb-4">
                      <span>📍</span> <%= booking.homeLocation %>
                    </p>
                  </div>
                  <span class="text-[10px] bg-blue-50 text-blue-600 font-extrabold px-3 py-1 rounded-full tracking-wider uppercase flex-shrink-0">
                    Confirmed
                  </span>
                </div>

                <!-- Booking Details Grid -->
                <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                  <div class="bg-gray-50 rounded-xl p-3">
                    <p class="text-[10px] text-gray-400 font-extrabold uppercase tracking-wider">Check-in</p>
                    <p class="text-sm font-bold text-gray-700 mt-0.5">📅 <%= booking.checkIn %></p>
                  </div>
                  <div class="bg-gray-50 rounded-xl p-3">
                    <p class="text-[10px] text-gray-400 font-extrabold uppercase tracking-wider">Check-out</p>
                    <p class="text-sm font-bold text-gray-700 mt-0.5">📅 <%= booking.checkOut %></p>
                  </div>
                  <div class="bg-gray-50 rounded-xl p-3">
                    <p class="text-[10px] text-gray-400 font-extrabold uppercase tracking-wider">Price / Night</p>
                    <p class="text-sm font-black text-[#FF5A5F] mt-0.5">₹<%= parseInt(booking.homePrice).toLocaleString('en-IN') %></p>
                  </div>
                  <div class="bg-gray-50 rounded-xl p-3">
                    <p class="text-[10px] text-gray-400 font-extrabold uppercase tracking-wider">Booked On</p>
                    <p class="text-sm font-bold text-gray-700 mt-0.5"><%= new Date(booking.bookedAt).toLocaleDateString('en-IN') %></p>
                  </div>
                </div>
              </div>

              <!-- Actions -->
              <div class="flex items-center gap-3 mt-4 pt-4 border-t border-gray-100">
                <a href="/homes/<%= booking.homeId %>" class="text-[#FF5A5F] text-xs font-bold hover:underline">
                  View Home →
                </a>
                <form action="/bookings/delete" method="POST" class="ml-auto"
                      onsubmit="return confirm('Are you sure you want to cancel this booking?')">
                  <input type="hidden" name="bookingId" value="<%= booking.id %>">
                  <button type="submit" class="bg-red-50 text-red-500 text-xs font-bold py-2 px-4 rounded-xl hover:bg-red-100 transition">
                    ✕ Cancel Booking
                  </button>
                </form>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </main>

</body>
</html>
