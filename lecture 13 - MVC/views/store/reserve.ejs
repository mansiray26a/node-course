<%- include('../partials/head') %>
<%- include('../partials/nav') %>

  <!-- Content -->
  <main class="max-w-lg mx-auto p-6 mt-16">
    <div class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden p-8 text-center">
      <div class="w-20 h-20 bg-emerald-50 rounded-full flex items-center justify-center mx-auto mb-6">
        <span class="text-4xl text-emerald-500">🎉</span>
      </div>
      <h1 class="text-3xl font-extrabold text-gray-800 font-serif mb-3 tracking-tight">Booking Confirmed!</h1>
      <p class="text-gray-500 mb-6 max-w-sm mx-auto">
        Your stay at <strong class="text-gray-800"><%= home.name %></strong> has been booked successfully.
      </p>

      <!-- Booking Summary -->
      <div class="bg-gray-50 rounded-2xl p-5 mb-6 text-left space-y-3">
        <div class="flex items-center gap-3">
          <div class="w-16 h-16 rounded-xl overflow-hidden shadow flex-shrink-0">
            <img src="<%= home.photoUrl %>" alt="<%= home.name %>" class="w-full h-full object-cover">
          </div>
          <div>
            <h3 class="font-bold text-gray-800 text-sm"><%= home.name %></h3>
            <p class="text-gray-500 text-xs flex items-center gap-1"><span>📍</span> <%= home.location %></p>
          </div>
        </div>
        <div class="border-t border-gray-200 pt-3 grid grid-cols-2 gap-3 text-sm">
          <div>
            <p class="text-[10px] text-gray-400 font-extrabold uppercase tracking-wider">Check-in</p>
            <p class="font-bold text-gray-700 mt-0.5">📅 <%= booking.checkIn %></p>
          </div>
          <div>
            <p class="text-[10px] text-gray-400 font-extrabold uppercase tracking-wider">Check-out</p>
            <p class="font-bold text-gray-700 mt-0.5">📅 <%= booking.checkOut %></p>
          </div>
        </div>
        <div class="border-t border-gray-200 pt-3 flex justify-between items-center">
          <span class="text-xs text-gray-400 font-bold">Price / Night</span>
          <span class="text-lg font-black text-[#FF5A5F]">₹<%= parseInt(home.price).toLocaleString('en-IN') %></span>
        </div>
      </div>

      <div class="flex flex-col gap-3">
        <a href="/bookings"
           class="inline-block bg-[#FF5A5F] text-white font-extrabold py-3.5 px-8 rounded-xl hover:bg-red-600 hover:scale-105 active:scale-95 shadow-md shadow-red-200 transition duration-200">
          View My Bookings
        </a>
        <a href="/homes"
           class="inline-block bg-gray-100 text-gray-700 font-bold py-3 px-8 rounded-xl hover:bg-gray-200 transition duration-200 text-sm">
          Continue Browsing
        </a>
      </div>
    </div>
  </main>

</body>
</html>
