<%- include('../partials/head') %>
<%- include('../partials/nav') %>

  <!-- Content -->
  <main class="max-w-5xl mx-auto p-6 md:p-8">
    <div class="flex items-center justify-between mt-8 mb-8">
      <div>
        <h1 class="text-3xl md:text-4xl font-extrabold text-gray-800 font-serif tracking-tight">My Listings</h1>
        <p class="text-gray-500 text-sm mt-1">Manage your registered homes</p>
      </div>
      <a href="/host/add-home" class="bg-[#FF5A5F] text-white px-6 py-3 rounded-xl font-bold text-sm hover:bg-red-600 hover:scale-105 shadow-md shadow-red-200 transition duration-300 flex items-center gap-1.5">
        <span>➕</span> Add New Home
      </a>
    </div>

    <% if (homes.length === 0) { %>
      <div class="text-center py-16 bg-white rounded-3xl shadow-xl border border-gray-100 max-w-xl mx-auto px-6">
        <span class="text-7xl block mb-6">📋</span>
        <h2 class="text-2xl font-bold text-gray-700 mb-3">No Listings Yet</h2>
        <p class="text-gray-500 mb-8 max-w-md mx-auto">You haven't registered any homes yet. Start hosting today!</p>
        <a href="/host/add-home" class="inline-block bg-[#FF5A5F] text-white px-8 py-3.5 rounded-xl font-bold text-lg hover:bg-red-600 hover:scale-105 shadow-md shadow-red-200 transition duration-300">
          Register Your First Home
        </a>
      </div>
    <% } else { %>
      <p class="text-gray-500 text-sm font-bold mb-6"><%= homes.length %> listing<%= homes.length > 1 ? 's' : '' %> registered</p>

      <div class="space-y-5">
        <% homes.forEach(home => { %>
          <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden flex flex-col md:flex-row hover:shadow-xl transition duration-300">
            <!-- Image -->
            <div class="md:w-56 h-44 md:h-auto overflow-hidden flex-shrink-0">
              <img src="<%= home.photoUrl %>" alt="<%= home.name %>"
                   class="w-full h-full object-cover">
            </div>

            <!-- Info -->
            <div class="flex-grow p-5 flex flex-col justify-between">
              <div>
                <h3 class="text-xl font-extrabold text-gray-800 mb-1"><%= home.name %></h3>
                <p class="text-gray-500 text-sm flex items-center gap-1.5 mb-3">
                  <span>📍</span> <%= home.location %>
                </p>

                <div class="flex flex-wrap gap-3 text-sm">
                  <span class="bg-gray-50 text-gray-600 px-3 py-1.5 rounded-lg font-bold flex items-center gap-1">
                    💰 ₹<%= parseInt(home.price).toLocaleString('en-IN') %>/night
                  </span>
                  <span class="bg-amber-50 text-amber-600 px-3 py-1.5 rounded-lg font-bold flex items-center gap-1">
                    ⭐ <%= parseFloat(home.rating).toFixed(1) %>/5.0
                  </span>
                  <span class="bg-emerald-50 text-emerald-600 px-3 py-1.5 rounded-lg font-bold flex items-center gap-1 text-xs">
                    ✅ Active
                  </span>
                </div>
              </div>

              <!-- Action Buttons: Edit and Delete -->
              <div class="flex items-center gap-3 mt-4 pt-4 border-t border-gray-100">
                <a href="/host/edit-home/<%= home.id %>"
                   class="bg-blue-50 text-blue-600 text-xs font-bold py-2.5 px-5 rounded-xl hover:bg-blue-100 transition flex items-center gap-1">
                  ✏️ Edit
                </a>
                <form action="/host/delete-home" method="POST"
                      onsubmit="return confirm('Are you sure you want to delete this listing? This action cannot be undone.')">
                  <input type="hidden" name="homeId" value="<%= home.id %>">
                  <button type="submit"
                          class="bg-red-50 text-red-500 text-xs font-bold py-2.5 px-5 rounded-xl hover:bg-red-100 transition flex items-center gap-1">
                    🗑️ Delete
                  </button>
                </form>
                <a href="/homes/<%= home.id %>" class="text-[#FF5A5F] text-xs font-bold hover:underline ml-auto">
                  View Listing →
                </a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </main>

</body>
</html>
